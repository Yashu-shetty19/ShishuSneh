<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:background="@drawable/bg_card_soft"
    android:padding="14dp" android:layout_marginTop="8dp">

    <TextView android:id="@+id/emoji"
        android:layout_width="48dp" android:layout_height="48dp"
        android:gravity="center" android:textSize="26sp"
        android:background="@drawable/bg_card_warm"/>
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical"
        android:layout_marginStart="12dp">
        <TextView android:id="@+id/title"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textStyle="bold" android:textColor="@color/text_primary"/>
        <TextView android:id="@+id/subtitle"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/text_muted" android:textSize="12sp"/>
    </LinearLayout>
    <CheckBox android:id="@+id/checkbox"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
</LinearLayout>
